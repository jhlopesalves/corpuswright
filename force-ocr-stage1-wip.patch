+            max_dimension: 3_200,
+            max_pixels: 10_000_000,
+        },
+        PdfOcrQuality::HighQuality => OcrRenderPreset {
+            dpi: 300.0,
+            max_dimension: 4_096,
+            max_pixels: 14_000_000,
+        },
+    }

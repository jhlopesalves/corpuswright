+fn render_preset(quality: PdfOcrQuality) -> OcrRenderPreset {
+    match quality {
+        PdfOcrQuality::Fast => OcrRenderPreset {
+            dpi: 150.0,
+            max_dimension: 2_400,
+            max_pixels: 6_000_000,
